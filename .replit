modules = ["python-3.10", "web", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "gcc", "gumbo", "harfbuzz", "jbig2dec", "libiconv", "libjpeg_turbo", "libxcrypt", "libyaml", "mupdf", "openjpeg", "postgresql", "python310", "rustc", "swig", "xcbuild"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'export LD_LIBRARY_PATH=$(dirname $(gcc -print-file-name=libstdc++.so.6)):$LD_LIBRARY_PATH && python run_server.py'"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "export LD_LIBRARY_PATH=.deploy-libs:$LD_LIBRARY_PATH; export PYTHONPATH=.pythonlibs/lib/python3.10/site-packages; export PATH=$PATH:.pythonlibs/bin:$HOME/.local/bin; exec gunicorn -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:5000 --reuse-port -w 2 --timeout 120 --graceful-timeout 30 'idpkit.api.app:create_app()'"]
build = ["bash", "build.sh"]
